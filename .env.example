## Catalitium example environment file
## Copy to `.env` and fill in real values. Never commit your real `.env`.

# --- Database ---
# Preferred: DATABASE_URL (Postgres / Supabase connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Legacy alias supported by the codebase; optional if DATABASE_URL is set.
SUPABASE_URL=

# --- Flask / app security ---
SECRET_KEY=change-me-to-a-long-random-string
ENV=development
FLASK_ENV=development
FLASK_DEBUG=1

# --- Rate limiting ---
# Default rate limit for anonymous endpoints (flask-limiter syntax).
# Example: "240 per minute"
RATE_LIMIT_DEFAULT=240 per minute

# Optional: shared storage for flask-limiter (multi-worker / multi-process).
# By default the app uses in-memory limits (memory://) and does NOT require Redis.
# Uncomment and point to Redis only if you explicitly add Redis to your infra.
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# --- SMTP for API key emails & contact forms ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=catalitium@gmail.com
SMTP_PASS=shlh xfvb ftwc ehzx
SMTP_FROM=noreply@catalitium.com

# --- Third-party APIs ---
# Used by /api/summary for AI-generated job bullets and skills.
ANTHROPIC_API_KEY=

# --- Trusted hosts / security headers (optional) ---
# TRUSTED_HOSTS=www.catalitium.com,catalitium.com


# Database (Supabase session pooler - IPv4 compatible, works everywhere)
# Format: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
# Port 5432 = session pooler (recommended). Port 6543 = PgBouncer transaction mode (avoid).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# Flask
SECRET_KEY=replace-with-64-char-random-hex
FLASK_ENV=production
FLASK_DEBUG=0

# Base URL (used in emails and sitemap)
BASE_URL=https://catalitium.com

# SMTP (email alerts and weekly digest)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=info@yourdomain.com

# Supabase API keys (for direct API calls if needed)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
# Supabase project URL (format: https://<ref>.supabase.co)
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co

# AI summaries (optional - feature returns 503 if not set)
ANTHROPIC_API_KEY=

# Rate limiting
RATE_LIMIT_DEFAULT=240 per minute
RATELIMIT_STORAGE_URI=memory://

# Security
TRUSTED_HOSTS=
MAX_CONTENT_LENGTH=1048576

# Database (Supabase session pooler - IPv4 compatible, works everywhere)
# Format: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
# Port 5432 = session pooler (recommended). Port 6543 = PgBouncer transaction mode (avoid).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# Flask
SECRET_KEY=replace-with-64-char-random-hex
FLASK_ENV=production
FLASK_DEBUG=0

# Cookiebot: add every hostname that serves the app (e.g. 127.0.0.1, localhost, staging, production)
# under Cookiebot Manager → Domains, or the consent banner and CDN scripts will fail on unauthorized hosts.

# Base URL (used in emails and sitemap)
BASE_URL=https://catalitium.com

# SMTP (email alerts and weekly digest)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=info@yourdomain.com

# Supabase (service_role key — get from Supabase Dashboard > Project Settings > API)
# SUPABASE_PUBLISHABLE_KEY is listed for reference but not used by the app
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
# Supabase project URL (format: https://<ref>.supabase.co)
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
# Password reset emails: add these to Supabase Dashboard → Authentication → URL configuration → Redirect URLs
#   http://127.0.0.1:5000/auth/confirm
#   https://your-production-domain/auth/confirm

# AI summaries (optional - feature returns 503 if not set)
ANTHROPIC_API_KEY=

# Brave Search API (optional - Carl B2B external context card hidden if not set)
# Get a key at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Rate limiting
RATE_LIMIT_DEFAULT=240 per minute
RATELIMIT_STORAGE_URI=memory://

# Security
TRUSTED_HOSTS=
MAX_CONTENT_LENGTH=1048576

# Stripe (get keys from Stripe Dashboard > Developers > API keys)
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_CORE_POST=price_xxx
STRIPE_PRICE_PREMIUM_POST=price_xxx
STRIPE_PRICE_ELITE_PLAN=price_xxx
# B2C subscriptions (Market Intelligence + API Access)
STRIPE_PRICE_MI_PREMIUM=price_xxx
STRIPE_PRICE_MI_PRO=price_xxx
STRIPE_PRICE_API_ACCESS=price_xxx
# Email for admin notifications on new job orders
ADMIN_EMAIL=your-admin@email.com

# Cache busting (use a date string e.g. 20260321)
ASSET_VERSION=20260321

# Multi-worker rate limiting: switch to redis://localhost:6379/0 if using 3+ Gunicorn workers
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# Go-live smoke (from repo root; DATABASE_URL required)
#   python scripts/smoke.py --section routes
#   python scripts/smoke.py --section all
#   (or individually: smoke_db_tables.py, supabase_smoke_test.py, smoke_routes_http.py)
# After deploy (hits public https://catalitium.com):
#   pwsh -File scripts/smoke_prod.ps1
